@echo off
chcp 65001 >nul
title 부동산 실거래가 앱 - 최초 1회 설치
echo.
echo ====================================================
echo   부동산 실거래가 앱 - 최초 1회 설치
echo ====================================================
echo.
echo Streamlit 및 의존성을 설치합니다... (1~3분 소요)
